#!/usr/bin/env bash
# lint-extras
# Version 3.2.0
declare -i RESULT=0

# Every file-based check enumerates via git; bail clearly if not in a work tree.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo 'lint-extras: not inside a Git working tree' >&2
  exit 2
fi

# List tracked + untracked (non-ignored) files matching the given pathspecs,
# dropping any that no longer exist on disk (e.g. tracked-but-deleted).
list_files() {
  local f
  git ls-files --cached --others --exclude-standard "$@" | while IFS= read -r f; do
    [ -e "$f" ] && printf '%s\n' "$f"
  done
}

# lint yaml files
mapfile -t files < <(list_files '*.yml' '*.yaml' ':!:.agents/skills/*')
[ ${#files[@]} -eq 0 ] || yamllint -s -- "${files[@]}"
RESULT+=$?

# ensure a lockfile
if test -f package.json; then
  if ! test -f yarn.lock && ! test -f package-lock.json; then
    echo 'No yarn.lock or package-lock.json file present'
    RESULT+=1
  fi
fi

# lint shell files
mapfile -t files < <(list_files '*.sh' '*.bash')
[ ${#files[@]} -eq 0 ] || shellcheck -- "${files[@]}"
RESULT+=$?

# lint lua files
mapfile -t files < <(list_files '*.lua')
[ ${#files[@]} -eq 0 ] || luacheck -q -- "${files[@]}"
RESULT+=$?

# lint Dockerfile
if test -f Dockerfile; then
  hadolint Dockerfile
  RESULT+=$?
fi

# lint markdown
if ! test -f README.md; then
  echo 'You must have at least a README.md (case sensitive)'
  RESULT+=1
fi

mapfile -t files < <(list_files '*.md' '*.markdown' ':!:.agents/skills/*')
[ ${#files[@]} -eq 0 ] || mdl "${files[@]}"
RESULT+=$?

exit $RESULT
